<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/screen_bg"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Header: Fitcrave + fire + crown -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvAppTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_name"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_fire"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_crown"
                    android:contentDescription="@null" />
            </LinearLayout>

            <!-- Stats row: Workouts / KCAL / MINUTES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="22dp"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvWorkoutsCount"
                        style="@style/StatNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="0" />
                    <TextView
                        style="@style/StatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/workouts" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvKcal"
                        style="@style/StatNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="0" />
                    <TextView
                        style="@style/StatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/kcal" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvMinutes"
                        style="@style/StatNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="0" />
                    <TextView
                        style="@style/StatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/minutes" />
                </LinearLayout>
            </LinearLayout>

            <!-- Weekly progress card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/weekly_progress"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/weeklyRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:weightSum="7">

                    <TextView
                        android:id="@+id/chip1" style="@style/WeeklyChip"
                        android:layout_weight="1"
                        android:background="@drawable/bg_weekly_chip"
                        android:text="1" />
                    <TextView
                        android:id="@+id/chip2" style="@style/WeeklyChip"
                        android:layout_weight="1"
                        android:background="@drawable/bg_weekly_chip"
                        android:text="2" />
                    <TextView
                        android:id="@+id/chip3" style="@style/WeeklyChip"
                        android:layout_weight="1"
                        android:background="@drawable/bg_weekly_chip"
                        android:text="3" />
                    <TextView
                        android:id="@+id/chip4" style="@style/WeeklyChip"
                        android:layout_weight="1"
                        android:background="@drawable/bg_weekly_chip"
                        android:text="4" />
                    <TextView
                        android:id="@+id/chip5" style="@style/WeeklyChip"
                        android:layout_weight="1"
                        android:background="@drawable/bg_weekly_chip"
                        android:text="5" />
                    <TextView
                        android:id="@+id/chip6" style="@style/WeeklyChip"
                        android:layout_weight="1"
                        android:background="@drawable/bg_weekly_chip"
                        android:text="6" />
                    <TextView
                        android:id="@+id/chip7" style="@style/WeeklyChip"
                        android:layout_weight="1"
                        android:background="@drawable/bg_weekly_chip_active"
                        android:text="7"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Tasks title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/tasks"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Workout + Diet horizontal row -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Workout card -->
                    <FrameLayout
                        android:id="@+id/cardWorkout"
                        android:layout_width="270dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_card_red"
                        android:clipChildren="true"
                        android:elevation="3dp">

                        <ImageView
                            android:layout_width="160dp"
                            android:layout_height="160dp"
                            android:layout_gravity="end|center_vertical"
                            android:layout_marginEnd="-10dp"
                            android:src="@drawable/ic_bodybuilder"
                            android:contentDescription="@null" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/workout"
                                android:textColor="@color/text_on_red"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvWorkoutDay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/day_zero"
                                android:textColor="@color/text_on_red"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                tools:text="DAY 0" />

                            <TextView
                                android:layout_width="160dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/workout_subtitle"
                                android:textColor="@color/text_on_red"
                                android:textSize="10sp" />

                            <Space
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/btnStartWorkout"
                                android:layout_width="170dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_start_button"
                                android:gravity="center"
                                android:text="@string/start"
                                android:textColor="@color/fitcrave_red"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </FrameLayout>

                    <!-- Diet card -->
                    <FrameLayout
                        android:id="@+id/cardDiet"
                        android:layout_width="270dp"
                        android:layout_height="180dp"
                        android:background="@drawable/bg_card_red_light"
                        android:elevation="3dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/diet"
                                android:textColor="@color/text_on_red"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDietDay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="DAY 0"
                                android:textColor="@color/text_on_red"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="160dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/diet_subtitle"
                                android:textColor="@color/text_on_red"
                                android:textSize="10sp" />

                            <Space
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/btnStartDiet"
                                android:layout_width="170dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_start_button"
                                android:gravity="center"
                                android:text="@string/start"
                                android:textColor="@color/fitcrave_red"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Report card -->
            <FrameLayout
                android:id="@+id/cardReport"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_red"
                android:elevation="3dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_report_hero"
                    android:contentDescription="@null" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/report_overlay" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="18dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/report"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </FrameLayout>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
